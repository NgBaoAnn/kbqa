# =============================================================================
# AegisHealth KBQA — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# Lines starting with # are comments.
#
# Secret variables (marked SECRET) must NEVER appear in frontend code,
# logs, API responses, or committed files.
# =============================================================================

# -----------------------------------------------------------------------------
# Neo4j AuraDB — Knowledge Graph
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<SECRET: your AuraDB password>   # SECRET

# -----------------------------------------------------------------------------
# Supabase — Auth + App Data
# -----------------------------------------------------------------------------
# Project URL (public, same as frontend VITE_SUPABASE_URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe for backend smoke tests; NOT a secret
SUPABASE_ANON_KEY=your_public_anon_key

# JWT secret for HS256 token verification (Settings → API → JWT Secret)
# Used by api_gateway/dependencies.py to verify Supabase access tokens.
SUPABASE_JWT_SECRET=<SECRET: your_supabase_jwt_secret>   # SECRET

# Service-role key — server-side only; bypasses RLS; NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=<SECRET: your_service_role_key>   # SECRET

# Postgres direct connection URL (pooler recommended for serverless)
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=<SECRET: postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres>   # SECRET

# -----------------------------------------------------------------------------
# AI / LLM Engine
# -----------------------------------------------------------------------------
# OpenAI-compatible endpoint (Ollama default: http://localhost:11434/v1)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=llama3:8b-instruct-q4_0
LLM_TIMEOUT_SECONDS=30

# Embedding model (same Ollama server, different model)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL_NAME=nomic-embed-text
EMBEDDING_DIM=768

# Default LightRAG query mode: mix | local | global | hybrid | naive
DEFAULT_QUERY_MODE=mix

# Set true to skip Cypher path and always go through LightRAG (dev/debug only)
DISABLE_CYPHER_PATH=false

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting for POST /api/v1/query (per IP, per minute)
RATE_LIMIT_PER_MINUTE=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
