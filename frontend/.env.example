# =============================================================================
# AegisHealth KBQA — Frontend Environment Variables
# =============================================================================
# Copy this file to .env (or .env.local) and fill in your values.
# NEVER commit the real .env file to git.
#
# All VITE_ variables are bundled into the browser build — never put secret
# keys (service-role key, DB URL, JWT secret) here.
# =============================================================================

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key (Settings → API → anon/public)
# Safe to expose in browser code — Supabase RLS enforces access control.
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# FastAPI backend base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000
